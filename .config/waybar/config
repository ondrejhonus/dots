{
	"layer": "top",	
	"position": "top",
    "height": 27,


    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": [],
    "modules-right": ["custom/spotify", "network", "network#wired", "pulseaudio", "battery", "custom/weather", "clock", "tray"],


	"sway/workspaces": {
        "disable-scroll": true,
        "disable-markup": true,
        "format": "{index}" 
},


	"sway/window": {
    	"format": "{}",
    	"max-length": 150
},

	"custom/spotify": {
    "interval": 10,
    "return-type": "json",
    "exec": "~/.config/waybar/custom/spotify.sh",
    "format": "   {}",
    "on-click": "spotifycli --next",
    "on-click-right": "spotifycli --prev",
    "on-click-middle": "spotifycli --playpause"
},

    "custom/weather": {
    "format": "{} ",
    "tooltip": true,
    "interval": 3600,
    "exec": "~/.config/waybar/custom/weather.sh",
    "return-type": "json"
},

	"custom/scratch": {
   		"interval": 3,
   		"exec": "swaymsg -t get_tree | jq 'recurse(.nodes[]) | first(select(.name==\"__i3_scratch\")) | .floating_nodes | length | select(. >= 0)'",
   		"format": "^{}", 
   		"on-click": "swaymsg 'scratchpad show'",
   		"on-click-right": "swaymsg 'move scratchpad'"
},


    "tray": {
        "icon-size": 18,
        "spacing": 15
},


    "clock": {
        // "format": "{:%a %b %e  %R:%S}",
	"format": "{:%d/%m   %R:%S}",
        "interval": 1,
        "tooltip": true,
        "tooltip-format": "{:%A, %B %d, %Y}"
},

    
    "battery": {
        "bat": "BAT0",
        "states": {
              "full": 90,
              "good": 80,
              "normal": 60,
              "warning": 20,
              "critical": 15
},

        "format": "{icon}  {capacity}% ",
        "format-good": "{icon}  {capacity}% ", 
        "format-full": "  {capacity}% ",
        "format-icons": ["", "", "", "", ""],
        "interval": 30,
        "format-alt": "{power} W ",
        "tooltip-format": "Battery: {capacity}%\nPower: {power} W\nTime: {time}\nHealth: {health}%"
},


    "network": {
        "interface": "wlp2s0", 
        "format-wifi": "  {essid}",
        "format-disconnected": "",
        "interval": 5,
        "format-alt": "{ipaddr}",
        "tooltip-format": "IF: {ifname}\nSSID: {essid}\nIP: {ipaddr}\nSignal: {signalStrength}%\nFreq: {frequency} GHz\nUp: {bandwidthUpBits}\nDown: {bandwidthDownBits}"
},

    "network#wired": {
        "interface": "enp0s25",
        "format-ethernet": "󰈀 ",
        "format-disconnected": "",
        "interval": 5,
        "format-alt": "{ipaddr}",
        "tooltip-format": "IF: {ifname}\nIP: {ipaddr}\nUp: {bandwidthUpBits}\nDown: {bandwidthDownBits}"
},


    "temperature": {
	   	"thermal-zone": 0,
		"format": "{icon} {temperatureC}°C",
		"format-icons":[""],
		"interval": 30
},


	"backlight": {
    	"device": "intel_backlight",
    	"format": "{icon}  {percent}%  ",
    	"format-icons": ["","","",""],
    	"interval": 60
},


    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "  {volume}%",
        "format-muted":"󰖁 ",
        "interval": 60,

        "format-icons": {
        "default": [""]
},
            
       "on-click": "blueman-manager"    


}

}
